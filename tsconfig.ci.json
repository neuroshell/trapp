{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "skipLibCheck": true,
    "noImplicitAny": false,
    "strict": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": ["src/**/*", "App.tsx"],
  "exclude": [
    "node_modules",
    "__tests__",
    "__mocks__",
    "scripts",
    "backend",
    "web-build"
  ]
}
