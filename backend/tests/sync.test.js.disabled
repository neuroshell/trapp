import { test, describe, beforeEach, afterEach } from 'node:test';
import assert from 'node:assert';
import { createServer } from '../index.js';
import { closeServer, createTempDb, cleanupTemp, authenticatedRequest, testId } from './test-utils.js';
import { clearDatabase, reinitializeDatabase } from '../db/index.js';

let tmpDir;
let dbFile;
let server;
let base;
let address;
let authToken;
let testUser;

beforeEach(async () => {
  const temp = await createTempDb();
  tmpDir = temp.tmpDir;
  dbFile = temp.dbFile;

  process.env.DB_FILE = dbFile;
  process.env.JWT_SECRET = 'test-secret-key-for-testing-only-min-32-chars';
  process.env.BCRYPT_ROUNDS = '4';
  
  // Reinitialize database with new file path
  await reinitializeDatabase();

  server = await createServer({ port: 0 });
  address = server.address();
  base = `http://127.0.0.1:${address.port}`;

  await clearDatabase();

  // Create and login test user
  const registerRes = await fetch(`${base}/api/auth/register`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      email: `${testId('user')}@example.com`,
      password: 'password123',
      username: 'synctestuser',
    }),
  });
  const registerJson = await registerRes.json();
  authToken = registerJson.token;
  testUser = registerJson.user;
});

afterEach(async () => {
  await closeServer(server);
  await cleanupTemp(tmpDir);
});

describe('Sync Endpoints', () => {
  describe('GET /api/sync', () => {
    test('should return user data with valid token', async () => {
      const res = await authenticatedRequest(base, '/api/sync', authToken);

      assert.strictEqual(res.status, 200);
      const json = await res.json();
      assert.strictEqual(json.success, true);
      assert.ok(json.data);
      assert.ok(Array.isArray(json.data.workouts));
      assert.ok(Array.isArray(json.data.achievements));
    });

    test('should reject request without token', async () => {
      const res = await fetch(`${base}/api/sync`);

      assert.strictEqual(res.status, 401);
    });

    test('should reject request with invalid token', async () => {
      const res = await authenticatedRequest(base, '/api/sync', 'invalid-token');

      assert.strictEqual(res.status, 401);
    });

    // TODO: Fix test - timing issue with timestamp filtering
    // test('should filter workouts by since parameter', async () => {
    //   // First, create a workout
    //   const workout = {
    //     type: 'running',
    //     timestamp: new Date().toISOString(),
    //     data: { distance: 5, duration: 30 },
    //   };

    //   await authenticatedRequest(base, '/api/sync/workout', authToken, {
    //     method: 'POST',
    //     body: JSON.stringify(workout),
    //   });

    //   // Wait a bit to ensure timestamp difference
    //   await new Promise((resolve) => setTimeout(resolve, 10));

    //   const since = new Date().toISOString();

    //   // Wait and create another workout
    //   await new Promise((resolve) => setTimeout(resolve, 10));
    //   await authenticatedRequest(base, '/api/sync/workout', authToken, {
    //     method: 'POST',
    //     body: JSON.stringify({
    //       type: 'pushups',
    //       timestamp: new Date().toISOString(),
    //       data: { reps: 20 },
    //     }),
    //   });

    //   // Fetch with since parameter
    //   const res = await authenticatedRequest(base, `/api/sync?since=${since}`, authToken);

    //   assert.strictEqual(res.status, 200);
    //   const json = await res.json();
    //   // Should only include the second workout
    //   assert.strictEqual(json.data.workouts.length, 1);
    //   assert.strictEqual(json.data.workouts[0].type, 'pushups');
    // });
  });

  describe('POST /api/sync', () => {
    test('should sync workouts successfully', async () => {
      const syncData = {
        workouts: [
          {
            id: 'workout-1',
            type: 'running',
            timestamp: new Date().toISOString(),
            data: { distance: 5, duration: 30 },
          },
          {
            id: 'workout-2',
            type: 'pushups',
            timestamp: new Date().toISOString(),
            data: { reps: 20, sets: 3 },
          },
        ],
      };

      const res = await authenticatedRequest(base, '/api/sync', authToken, {
        method: 'POST',
        body: JSON.stringify(syncData),
      });

      assert.strictEqual(res.status, 200);
      const json = await res.json();
      assert.strictEqual(json.success, true);
    });

    test('should sync achievements successfully', async () => {
      const syncData = {
        achievements: [
          {
            id: 'achievement-1',
            name: 'First Workout',
            description: 'Complete your first workout',
            unlockedAt: new Date().toISOString(),
          },
        ],
      };

      const res = await authenticatedRequest(base, '/api/sync', authToken, {
        method: 'POST',
        body: JSON.stringify(syncData),
      });

      assert.strictEqual(res.status, 200);
      const json = await res.json();
      assert.strictEqual(json.success, true);
    });

    test('should handle empty sync payload', async () => {
      const res = await authenticatedRequest(base, '/api/sync', authToken, {
        method: 'POST',
        body: JSON.stringify({}),
      });

      assert.strictEqual(res.status, 200);
      const json = await res.json();
      assert.strictEqual(json.success, true);
    });

    test('should reject invalid workout type', async () => {
      const syncData = {
        workouts: [
          {
            id: 'invalid-workout',
            type: 'invalid-type',
            timestamp: new Date().toISOString(),
            data: {},
          },
        ],
      };

      const res = await authenticatedRequest(base, '/api/sync', authToken, {
        method: 'POST',
        body: JSON.stringify(syncData),
      });

      assert.strictEqual(res.status, 400);
    });

    test('should resolve conflicts with last-write-wins', async () => {
      // Create initial workout
      const workout = {
        id: 'conflict-workout',
        type: 'running',
        timestamp: new Date().toISOString(),
        data: { distance: 5, duration: 30 },
        updatedAt: new Date().toISOString(),
      };

      await authenticatedRequest(base, '/api/sync/workout', authToken, {
        method: 'POST',
        body: JSON.stringify(workout),
      });

      // Wait to create newer update
      await new Promise((resolve) => setTimeout(resolve, 10));

      // Sync with updated workout (newer timestamp)
      const updatedWorkout = {
        ...workout,
        data: { distance: 10, duration: 60 },
        updatedAt: new Date().toISOString(),
      };

      const res = await authenticatedRequest(base, '/api/sync', authToken, {
        method: 'POST',
        body: JSON.stringify({ workouts: [updatedWorkout] }),
      });

      assert.strictEqual(res.status, 200);
      const json = await res.json();
      // Should have no conflicts since client has newer timestamp
      assert.strictEqual(json.conflicts, 0);
    });
  });

  describe('POST /api/sync/workout', () => {
    test('should save single workout successfully', async () => {
      const workout = {
        type: 'running',
        timestamp: new Date().toISOString(),
        data: { distance: 5, duration: 30 },
      };

      const res = await authenticatedRequest(base, '/api/sync/workout', authToken, {
        method: 'POST',
        body: JSON.stringify(workout),
      });

      assert.strictEqual(res.status, 201);
      const json = await res.json();
      assert.strictEqual(json.success, true);
      assert.strictEqual(json.workout.type, 'running');
      assert.strictEqual(json.workout.data.distance, 5);
    });

    test('should save strength workout successfully', async () => {
      const workout = {
        type: 'pushups',
        timestamp: new Date().toISOString(),
        data: { reps: 25, sets: 4 },
      };

      const res = await authenticatedRequest(base, '/api/sync/workout', authToken, {
        method: 'POST',
        body: JSON.stringify(workout),
      });

      assert.strictEqual(res.status, 201);
      const json = await res.json();
      assert.strictEqual(json.success, true);
      assert.strictEqual(json.workout.type, 'pushups');
      assert.strictEqual(json.workout.data.reps, 25);
    });

    test('should reject workout without type', async () => {
      const workout = {
        timestamp: new Date().toISOString(),
        data: { distance: 5 },
      };

      const res = await authenticatedRequest(base, '/api/sync/workout', authToken, {
        method: 'POST',
        body: JSON.stringify(workout),
      });

      assert.strictEqual(res.status, 400);
    });

    test('should reject workout without timestamp', async () => {
      const workout = {
        type: 'running',
        data: { distance: 5 },
      };

      const res = await authenticatedRequest(base, '/api/sync/workout', authToken, {
        method: 'POST',
        body: JSON.stringify(workout),
      });

      assert.strictEqual(res.status, 400);
    });

    test('should reject invalid distance value', async () => {
      const workout = {
        type: 'running',
        timestamp: new Date().toISOString(),
        data: { distance: 150 }, // Over 100 km limit
      };

      const res = await authenticatedRequest(base, '/api/sync/workout', authToken, {
        method: 'POST',
        body: JSON.stringify(workout),
      });

      assert.strictEqual(res.status, 400);
    });

    test('should reject invalid reps value', async () => {
      const workout = {
        type: 'pushups',
        timestamp: new Date().toISOString(),
        data: { reps: 2000 }, // Over 1000 limit
      };

      const res = await authenticatedRequest(base, '/api/sync/workout', authToken, {
        method: 'POST',
        body: JSON.stringify(workout),
      });

      assert.strictEqual(res.status, 400);
    });
  });

  describe('PUT /api/sync/workout/:id', () => {
    test('should update existing workout', async () => {
      // Create workout first
      const createRes = await authenticatedRequest(base, '/api/sync/workout', authToken, {
        method: 'POST',
        body: JSON.stringify({
          type: 'running',
          timestamp: new Date().toISOString(),
          data: { distance: 5, duration: 30 },
        }),
      });
      const workoutId = (await createRes.json()).workout.id;

      // Update workout
      const updateRes = await authenticatedRequest(base, `/api/sync/workout/${workoutId}`, authToken, {
        method: 'PUT',
        body: JSON.stringify({
          type: 'running',
          timestamp: new Date().toISOString(),
          data: { distance: 10, duration: 60 },
        }),
      });

      assert.strictEqual(updateRes.status, 200);
      const json = await updateRes.json();
      assert.strictEqual(json.success, true);
      assert.strictEqual(json.workout.data.distance, 10);
    });
  });

  describe('DELETE /api/sync/workout/:id', () => {
    test('should delete workout successfully', async () => {
      // Create workout first
      const createRes = await authenticatedRequest(base, '/api/sync/workout', authToken, {
        method: 'POST',
        body: JSON.stringify({
          type: 'running',
          timestamp: new Date().toISOString(),
          data: { distance: 5, duration: 30 },
        }),
      });
      const workoutId = (await createRes.json()).workout.id;

      // Delete workout
      const deleteRes = await authenticatedRequest(base, `/api/sync/workout/${workoutId}`, authToken, {
        method: 'DELETE',
      });

      assert.strictEqual(deleteRes.status, 200);
      const json = await deleteRes.json();
      assert.strictEqual(json.success, true);
      assert.strictEqual(json.deletedId, workoutId);

      // Verify deletion
      const getRes = await authenticatedRequest(base, '/api/sync', authToken);
      const userData = (await getRes.json()).data;
      assert.strictEqual(userData.workouts.length, 0);
    });
  });

  describe('POST /api/sync/achievement', () => {
    test('should save achievement successfully', async () => {
      const achievement = {
        id: 'first-workout',
        name: 'First Workout',
        description: 'Complete your first workout',
        category: 'milestone',
        unlockedAt: new Date().toISOString(),
      };

      const res = await authenticatedRequest(base, '/api/sync/achievement', authToken, {
        method: 'POST',
        body: JSON.stringify(achievement),
      });

      assert.strictEqual(res.status, 201);
      const json = await res.json();
      assert.strictEqual(json.success, true);
      assert.strictEqual(json.achievement.name, 'First Workout');
    });

    test('should reject achievement without id', async () => {
      const achievement = {
        name: 'Test Achievement',
        description: 'Test',
      };

      const res = await authenticatedRequest(base, '/api/sync/achievement', authToken, {
        method: 'POST',
        body: JSON.stringify(achievement),
      });

      assert.strictEqual(res.status, 400);
    });

    test('should reject achievement without name', async () => {
      const achievement = {
        id: 'test-achievement',
        description: 'Test',
      };

      const res = await authenticatedRequest(base, '/api/sync/achievement', authToken, {
        method: 'POST',
        body: JSON.stringify(achievement),
      });

      assert.strictEqual(res.status, 400);
    });
  });
});
