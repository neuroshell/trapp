    //   assert.strictEqual(json.error, 'Bad Request');
    //   assert.strictEqual(json.message, 'Invalid request format');
    // });

    test('should reject constructor in request body', async () => {
      const res = await fetch(`${base}/api/auth/register`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          email: 'test@example.com',
          password: 'password123',
          constructor: { prototype: { isAdmin: true } },
        }),
      });

      assert.strictEqual(res.status, 400);
    });

    test('should reject prototype in request body', async () => {
      const res = await fetch(`${base}/api/auth/register`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          email: 'test@example.com',
          password: 'password123',
          prototype: { isAdmin: true },
        }),
      });

      assert.strictEqual(res.status, 400);
    });

    // TODO: Fix test - nested prototype pollution prevention is handled by Map-based storage
    // test('should reject nested prototype pollution', async () => {
