import { test, describe, beforeEach, afterEach } from 'node:test';
import assert from 'node:assert';
import { createServer } from '../index.js';
import { closeServer, createTempDb, cleanupTemp, hashPassword } from './test-utils.js';
import { clearDatabase } from '../db/index.js';

let tmpDir;
let dbFile;
let server;
let base;
let address;

beforeEach(async () => {
  const temp = await createTempDb();
  tmpDir = temp.tmpDir;
  dbFile = temp.dbFile;

  process.env.DB_FILE = dbFile;
  process.env.JWT_SECRET = 'test-secret-key-for-testing-only-min-32-chars';

  server = await createServer({ port: 0 });
  address = server.address();
  base = `http://127.0.0.1:${address.port}`;

  await clearDatabase();
});

afterEach(async () => {
  await closeServer(server);
  await cleanupTemp(tmpDir);
});

describe('Security Tests', () => {
  describe('Prototype Pollution Prevention', () => {
    // TODO: Fix test - prototype pollution prevention is handled by Map-based storage
