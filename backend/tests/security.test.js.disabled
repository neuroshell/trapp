    //         __proto__: { isAdmin: true },
    //       },
    //     }),
    //   });

    //   assert.strictEqual(res.status, 400);
    // });
  });

  describe('Input Validation', () => {
    test('should reject oversized JSON payload', async () => {
      const largePayload = {
        email: 'test@example.com',
        password: 'password123',
        data: 'x'.repeat(3 * 1024 * 1024), // 3MB
      };

      const res = await fetch(`${base}/api/auth/register`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(largePayload),
      });

      // Should be rejected due to payload size limit (2mb)
      assert.ok([400, 413].includes(res.status));
    });

    test('should reject invalid content type', async () => {
      const res = await fetch(`${base}/api/auth/register`, {
        method: 'POST',
        headers: { 'Content-Type': 'text/plain' },
        body: 'email=test@example.com&password=password123',
      });

      // Express may parse or reject depending on configuration
      assert.ok([400, 415].includes(res.status));
    });

    // TODO: Fix test - email normalization behavior needs verification
    // test('should sanitize email input', async () => {
    //   const res = await fetch(`${base}/api/auth/register`, {
    //     method: 'POST',
    //     headers: { 'Content-Type': 'application/json' },
    //     body: JSON.stringify({
    //       email: '  TEST@EXAMPLE.COM  ',
    //       password: 'password123',
    //     }),
    //   });

    //   assert.strictEqual(res.status, 201);
    //   const json = await res.json();
    //   assert.strictEqual(json.user.email, 'test@example.com');
    // });
  });

  describe('Security Headers', () => {
    test('should include HSTS header', async () => {
      const res = await fetch(`${base}/api/health`);

      assert.strictEqual(res.status, 200);
      const hsts = res.headers.get('strict-transport-security');
      assert.ok(hsts);
      assert.ok(hsts.includes('max-age='));
    });

    test('should include X-Content-Type-Options header', async () => {
      const res = await fetch(`${base}/api/health`);

      assert.strictEqual(res.status, 200);
      const contentTypeOptions = res.headers.get('x-content-type-options');
      assert.strictEqual(contentTypeOptions, 'nosniff');
    });

    test('should include X-Frame-Options header', async () => {
      const res = await fetch(`${base}/api/health`);

      assert.strictEqual(res.status, 200);
      const frameOptions = res.headers.get('x-frame-options');
      assert.ok(frameOptions);
    });

    test('should include Content-Security-Policy header', async () => {
      const res = await fetch(`${base}/api/health`);

      assert.strictEqual(res.status, 200);
      const csp = res.headers.get('content-security-policy');
      assert.ok(csp);
    });

    test('should include X-XSS-Protection header', async () => {
      const res = await fetch(`${base}/api/health`);

      assert.strictEqual(res.status, 200);
      const xssProtection = res.headers.get('x-xss-protection');
      assert.ok(xssProtection);
    });
  });

  describe('CORS Configuration', () => {
    test('should allow requests from configured origins', async () => {
      const res = await fetch(`${base}/api/health`, {
        headers: {
          Origin: 'http://localhost:8081',
        },
      });

      assert.strictEqual(res.status, 200);
      const acao = res.headers.get('access-control-allow-origin');
      assert.strictEqual(acao, 'http://localhost:8081');
    });

    // TODO: Fix test - CORS behavior needs verification
    // test('should reject requests from non-configured origins', async () => {
    //   const res = await fetch(`${base}/api/health`, {
    //     headers: {
    //       Origin: 'http://malicious-site.com',
    //     },
    //   });

    //   // CORS rejection happens at browser level, server still responds
    //   // but without CORS headers
    //   assert.strictEqual(res.status, 200);
    //   const acao = res.headers.get('access-control-allow-origin');
    //   assert.notStrictEqual(acao, 'http://malicious-site.com');
    // });

    test('should handle preflight OPTIONS requests', async () => {
      const res = await fetch(`${base}/api/health`, {
        method: 'OPTIONS',
        headers: {
          Origin: 'http://localhost:8081',
          'Access-Control-Request-Method': 'GET',
          'Access-Control-Request-Headers': 'Content-Type',
        },
      });

      assert.strictEqual(res.status, 204);
    });
  });

  describe('Rate Limiting', () => {
    test('should allow requests within rate limit', async () => {
      // Make a few requests within the limit
      for (let i = 0; i < 5; i++) {
        const res = await fetch(`${base}/api/health`);
        assert.strictEqual(res.status, 200);
      }
    });

    // TODO: Fix test - rate limiting disabled in test environment
