{
  "name": "trapp",
  "version": "0.1.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:web": "npx expo export -p web",
    "lint": "eslint . --ext .ts,.tsx",
    "test:app": "jest",
    "test:ci": "node test-ci.js",
    "test:backend": "cd backend && npm test",
    "test": "npm run test:app && npm run test:backend",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:e2e:chromium": "playwright test --project=chromium",
    "test:e2e:mobile": "playwright test --project='Mobile Chrome' --project='Mobile Safari'",
    "test:e2e:install": "playwright install",
    "test:e2e:install-deps": "playwright install-deps",
    "test:e2e:clean": "rimraf playwright-results playwright-report playwright-results",
    "test:all": "npm run test:app && npm run test:backend && npm run test:e2e",
    "agents:process": "ts-node scripts/agents/process-backlog.ts",
    "agents:watch": "ts-node scripts/agents/process-backlog.ts --watch",
    "agents:issue": "ts-node scripts/agents/process-backlog.ts --issue",
    "agents:setup": "node scripts/setup-agents.js"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@octokit/rest": "^20.0.2",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-native": "^5.0.0",
    "@testing-library/react-native": "^12.1.4",
    "@types/node": "^20.11.0",
    "@types/react": "~19.1.10",
    "commander": "^12.0.0",
    "eslint": "8.57.0",
    "eslint-config-universe": "^15.0.3",
    "jest": "^29.6.0",
    "jest-expo": "~54.0.17",
    "jest-junit": "^16.0.0",
    "playwright-core": "^1.58.2",
    "react-test-renderer": "19.1.0",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.2"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-community/netinfo": "^12.0.1",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/native-stack": "^7.14.5",
    "@react-navigation/stack": "^7.8.5",
    "expo-crypto": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "react-dom": "19.1.0",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-modal-datetime-picker": "^18.0.0",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.24.0",
    "react-native-web": "^0.21.0"
  }
}
