# Agentic SDLC Pipeline - Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# REQUIRED: GitHub Authentication
# =============================================================================

# GitHub Personal Access Token with repo and workflow scopes
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here

# =============================================================================
# REQUIRED: Repository Information
# =============================================================================

# GitHub username or organization name
GITHUB_REPO_OWNER=neuroshell

# Repository name (without owner)
GITHUB_REPO_NAME=trapp

# =============================================================================
# OPTIONAL: Pipeline Configuration
# =============================================================================

# Timeout for each agent execution (milliseconds)
# Default: 300000 (5 minutes)
AGENT_TIMEOUT=300000

# Maximum number of concurrent agents
# Default: 3
AGENT_CONCURRENCY=3

# Timeout for approval gates (milliseconds)
# Default: 86400000 (24 hours)
APPROVAL_TIMEOUT=86400000

# Polling interval for approval checks (milliseconds)
# Default: 300000 (5 minutes)
POLL_INTERVAL=300000

# Watch mode interval (milliseconds)
# Default: 60000 (1 minute)
WATCH_INTERVAL=60000

# =============================================================================
# OPTIONAL: Feature Flags
# =============================================================================

# Enable verbose logging (true/false)
# Default: false
VERBOSE=false

# Dry run mode - no changes made to GitHub (true/false)
# Default: false
DRY_RUN=false

# Auto-create pull requests (true/false)
# Default: true
AUTO_CREATE_PR=true

# Branch prefix for agent-generated code
# Default: agent-pipeline/
BRANCH_PREFIX=agent-pipeline/
